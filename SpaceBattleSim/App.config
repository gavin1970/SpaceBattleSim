<?xml version="1.0" encoding="utf-8" ?>
<configuration>
		<appSettings>
				<!-- ###############[ System Settings ]############### -->
				<!-- 
				This states if the sim should run in full screen across all screens or full screen, current window.  
				Full screen mode across all screens is a nice effect, but it can cause some performance issues on older machines.
				Options: FullScreenAll, Windowed, FullScreenCurrent (default)
				-->
				<add key="ScreenViewType" value="FullScreenCurrent"/>
				<!-- 
				Refresh Rate is Frames Per Second (FPS). Value values: 60, 30, 20, or 10.  It will be converted to milliseconds behind the scenes.  
				This is the time between each frame update, and it can be adjusted to improve performance on older machines.
				Understanding the following values will auto adjust ship speeds, internally, so they are not running too fast or too slow.
				- (60) - FPS = 16ms - Smooth on most machines, but can cause performance issues on older machines.  (15% cpu)
				- (30) - FPS = 33ms - Smooth on most machines, and is a good option, works on older machines.  (9% cpu)
				- (20) - FPS = 50ms - Smooth on most machines, and is the default.  (5% cpu)
				- (10) - FPS = 100ms - Not smooth, but can be used on very old machines, and is a good option for debugging, as it slows down the sim.  (3% cpu)
				Default: 20 - (50ms is around 20 FPS)
				-->
				<add key="RefreshRate" value="20"/>
				<!-- 
				Disables Windows auto-lock / screensaver feature.
				-->
				<add key="DisableAutoLock" value="false"/>
				<!-- 
				Sets the window to be always on top of other windows.  This is a nice effect, but it can cause some issues 
				if you need to access other windows while the sim is running.
				-->
				<add key="TopmostWindow" value="false"/>
				<!-- 
				Enables internal battlefield logging ".\audit\", which can be used for debugging and performance analysis.
				-->
				<add key="AuditLogEnabled" value="false"/>


				<!-- ###############[ Battle Settings ]############### -->
				<!-- 
				Show a faint Matrix grid in the background.
				This is a nice effect as it enhances the visual appeal if stars, but overlooked because of stars, until you turn it off.
				-->
				<add key="ShowMatrixGrid" value="true"/>
				<!-- 
				Show the app version near the bottom left of the screen.
				-->
				<add key="ShowVersion" value="true"/>
				<!-- 
				Limited range, 10 - 150. Total number of battle ships in the simulation.  
				This covers only Fighters and Raiders, and does not include Capital Ships or RepairRigs/Healers.
				Capital Ships and RepairRigs/Healers will be 10% of the total BattleShips configured.
				The more ships, the more CPU intensive the sim becomes.
				-->
				<add key="TotalBattleShips" value="30"/>
				<!-- 
				When using unicode, the ship can have a faint shadow behind it, which can help with visibility against the background.
				-->
				<add key="UseShadowing" value="false"/>
				<!-- 
				Use unicode to display ships.  If false, the unicode characters are rendered as images and uses 
				a black overlay to get darker as the ship takes on more damage.
				-->
				<add key="UseUnicodeShips" value="true"/>
				<!-- 
				Show a planet in the background.  
				This is a nice effect, but it can cause some performance issues on older machines.
				-->
				<add key="ShowPlanets" value="true"/>
				<!-- 
				Planet texture file.  This is the file path to the planet texture, which must be under the .\skins\ folder.  
				The default is .\skins\fungal_planet.png, but you can change it to any other texture file (png, jpg, or bmp), as long as it's 
				under the .\skins\ folder.
				-->
				<add key="PlanetTextureFile" value=".\skins\jupiter-surface.jpg"/>
				<!-- 
				Limited range, 50 - 400.  this is the size of the planet.  
				Any larger, will cause it to look like a giant ball, and any smaller, will make it look like a star.
				-->
				<add key="PlanetSize" value="100"/>
				<!-- 
				Limited range, 0.0 - 0.5.  this is the speed in which the planet rotates.  
				Any faster, will ramp up your CPU.  0.0 will make it static, and 0.5 will make it rotate quicker.
				-->
				<add key="PlanetSpinSpeed" value="0.1"/>
				<!-- 
				Show stars in the background.  This is a nice effect, and is only written once, 
				generating a bitmap with nebulae, so it should not cause any performance issues on older machines.
				-->
				<add key="ShowStars" value="true"/>
				<!-- 
				If ShowStars = true and NaturalStarfield = true, then display natural starfield.  
				If ShowStars = false provides a more uniform star distribution that might look more like large plus symbols.
				Rather set as true or false, if ShowStars is true, it's created one time as a cached bitmap to help lower CPU costs.
				-->
				<add key="NaturalStarfield" value="true"/>
				<!-- 
				Shows the animated comet flying across the screen.  
				This is a nice effect, but it can cause some performance issues on older machines.
				-->
				<add key="ShowComet" value="true"/>
				<!-- 
				Shows the 3 nebula in the background.  This is a nice effect, and is only written once, 
				generating a bitmap with stars, so it should not cause any performance issues on older machines.
				-->
				<add key="ShowNebulae" value="true"/>


				<!-- ###############[ ShipType Specific Settings ]############### -->
				<!-- 
				Allows a raider to transfer half their power for 100% to their shields, when they drop below 25% shields. 
				This can happen multiple times in a battle, but will not occur if (power / 2 < 2).
				Shields will change color each time. 
						(Green=16 power, Cyan=8 power, Orange=4 power, Silver=2 power, Red=2 power and less than 25% shields)
				-->
				<add key="CriticalTransferRaiders" value="false"/>
				<!-- 
				Allows a ally, both Fighters and Capital ships to transfer half their power to their shields, when they drop below 25% shields.
				Since RepairRigs/Healers have 2 Power, they will not transfer, but they are included in this option, just in case, that changes in the future.
				Shields will change color each time:
						CapitalShips: (Green=8 power, Cyan=4 power, Orange=2 power, Red=2 power and less than 25% shields)
						FighterShips: (Green=4 power, Cyan=2 power, Red=2 power and less than 25% shields)
				-->
				<add key="CriticalTransferAlly" value="false"/>
		</appSettings>
</configuration>